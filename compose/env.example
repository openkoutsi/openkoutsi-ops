# Reference for the NON-SECRET environment consumed by docker-compose.yml.
#
# On the VM these values are written by cloud-init to /opt/openkoutsi/stack.env
# (rendered from OpenTofu variables) and loaded by okdeploy-pull.sh — you do NOT
# edit this file in production. It exists for local inspection / `docker compose
# config` and to document every interpolated variable.
#
# SECRETS ARE NOT HERE. They are delivered as files under ./secrets/<name> and
# mounted at /run/secrets/<name>. Never put secret_key, encryption_key,
# *_client_secret, bridge_secret, wahoo_webhook_token, etc. in env.

# Absolute path of the mounted encrypted data device (data volumes bind here).
DATA_MOUNT=/opt/openkoutsi/data

# Absolute path for logs on the VM's OS disk (nginx + service-log volumes bind
# here). Deliberately NOT under DATA_MOUNT: logs are transient and pruned, so they
# are kept off the encrypted, backed-up data device.
LOG_MOUNT=/opt/openkoutsi/logs

# TLS bootstrap (consumed by scripts/init-certs.sh). One SAN cert named CERT_NAME
# covers every hostname; all nginx server blocks point at live/<CERT_NAME>/.
CERT_NAME=openkoutsi
CERT_DOMAINS="openkoutsi.example api.openkoutsi.example bridge.openkoutsi.example wahoo-bridge.openkoutsi.example stats.openkoutsi.example logs.openkoutsi.example metrics.openkoutsi.example"
CERT_EMAIL=admin@openkoutsi.example
CERT_STAGING=0   # 1 = Let's Encrypt staging (untrusted, no rate limits) while testing

# Public URLs (drive CORS, OAuth redirects and bridge callbacks).
# FRONTEND_URL is the web app's own public origin; it is also passed to the web
# container as BASE_URL, which Next.js uses to render robots.txt / sitemap.xml.
FRONTEND_URL=https://openkoutsi.example
API_URL=https://api.openkoutsi.example
BRIDGE_URL=https://bridge.openkoutsi.example
WAHOO_BRIDGE_URL=https://wahoo-bridge.openkoutsi.example

# OAuth client IDs (public identifiers, not secrets).
STRAVA_CLIENT_ID=
WAHOO_CLIENT_ID=

# Inbound email (issue #38) — opt-in, off by default. COMPOSE_PROFILES gates the
# inbound_bridge service (empty = not started); the INBOUND_* vars configure the
# backend poller. The bridge's signing/bearer secrets are SECRETS
# (./secrets/inbound_bridge_secret, ./secrets/euromail_webhook_secret). When
# enabled, add INBOUND_BRIDGE_URL to the SAN cert (CERT_DOMAINS) too.
COMPOSE_PROFILES=
INBOUND_EMAIL_ENABLED=false
INBOUND_EMAIL_ADDRESS=
INBOUND_BRIDGE_URL=

# Outbound transactional email (issue #15) — powers self-serve email signup and
# password reset. Non-secret selection + sender address; the provider API token is
# a SECRET (./secrets/lettermint_api_key or ./secrets/euromail_api_key). Leave
# EMAIL_FROM empty (and the key file empty) to keep email — and thus self-serve
# signup/reset — disabled; the admin toggle then has no effect.
EMAIL_PROVIDER=lettermint
EMAIL_FROM=

# LLM base URL / model / API key are configured on the admin settings page
# (InstanceSettings), not via deployment env. LLM_ALLOWED_SERVERS is an env-only
# SSRF allowlist guard (optional).
LLM_ALLOWED_SERVERS=

# Subscription gating for LLM features (issue #9) is a per-instance admin toggle
# (InstanceSettings.llm_requires_subscription), not an env var — no config needed
# here in Phase 1. Per-user token usage for instance-paid LLM calls is recorded
# in a separate database; LLM_USAGE_DB overrides its path (default
# <DATA_DIR>/llm_usage.db). Leave empty to use the default.
LLM_USAGE_DB=

# Days to keep per-service log files (Vector → ${LOG_MOUNT}/service_logs) before
# the oklog-prune timer deletes them.
LOG_RETENTION_DAYS=30

# nginx access-log size cap (enforced by the oknginx-logrotate timer). When
# ${LOG_MOUNT}/nginx_logs/access.log grows past NGINX_ACCESS_LOG_MAX_MB it is
# rotated + gzip'd; NGINX_ACCESS_LOG_KEEP compressed generations are retained.
NGINX_ACCESS_LOG_MAX_MB=100
NGINX_ACCESS_LOG_KEEP=5
