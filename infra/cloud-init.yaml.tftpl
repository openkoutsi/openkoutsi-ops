#cloud-config
# Rendered by OpenTofu (templatefile) and passed as user-data. This is the ONLY
# place the VM is configured. Re-provision to change the box.
#
# NOTE: user-data is readable from inside the instance and contains secrets —
# acceptable per issue #5 ("cloud-init only"); the data device is encrypted.

users:
  - name: deploy
    groups: [docker, sudo]
    shell: /bin/bash
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    ssh_authorized_keys:
%{ for key in ssh_public_keys ~}
      - ${key}
%{ endfor ~}

package_update: true
package_upgrade: true
packages:
  - ca-certificates
  - curl
  - gnupg

write_files:
  # ── App deployment config ──────────────────────────────────────────────
  - path: /opt/openkoutsi/docker-compose.yml
    permissions: "0644"
    content: |
      ${indent(6, docker_compose)}

  - path: /opt/openkoutsi/nginx/nginx.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_conf)}

  - path: /opt/openkoutsi/nginx/conf.d/api.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_api)}

  - path: /opt/openkoutsi/nginx/conf.d/web.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_web)}

  - path: /opt/openkoutsi/nginx/conf.d/landing.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_landing)}

  - path: /opt/openkoutsi/nginx/conf.d/strava-bridge.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_strava_bridge)}

  - path: /opt/openkoutsi/nginx/conf.d/wahoo-bridge.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_wahoo_bridge)}

  - path: /opt/openkoutsi/nginx/conf.d/goaccess.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_goaccess)}

  - path: /opt/openkoutsi/nginx/conf.d/logs.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_logs)}

  - path: /opt/openkoutsi/nginx/conf.d/metrics.conf
    permissions: "0644"
    content: |
      ${indent(6, nginx_metrics)}

  - path: /opt/openkoutsi/goaccess/goaccess.conf
    permissions: "0644"
    content: |
      ${indent(6, goaccess_conf)}

  - path: /opt/openkoutsi/vector/vector.yaml
    permissions: "0644"
    content: |
      ${indent(6, vector_conf)}

  - path: /opt/openkoutsi/netdata/netdata.conf
    permissions: "0644"
    content: |
      ${indent(6, netdata_conf)}

  # ── Non-secret environment (plain env, NOT secrets) ────────────────────
  - path: /opt/openkoutsi/stack.env
    permissions: "0644"
    content: |
      DATA_MOUNT=${data_mount}
      LOG_MOUNT=${log_mount}
      FRONTEND_URL=https://${web_fqdn}
      API_URL=https://${api_fqdn}
      BRIDGE_URL=https://${strava_bridge_fqdn}
      WAHOO_BRIDGE_URL=https://${wahoo_bridge_fqdn}
      STRAVA_CLIENT_ID=${strava_client_id}
      WAHOO_CLIENT_ID=${wahoo_client_id}
      LLM_ALLOWED_SERVERS=${llm_allowed_servers}
      LOG_RETENTION_DAYS=${log_retention_days}
      NGINX_ACCESS_LOG_MAX_MB=${nginx_access_log_max_mb}
      NGINX_ACCESS_LOG_KEEP=${nginx_access_log_keep}
      CERT_NAME=openkoutsi
      CERT_DOMAINS="${landing_fqdn} ${web_fqdn} ${api_fqdn} ${strava_bridge_fqdn} ${wahoo_bridge_fqdn} ${stats_fqdn} ${logs_fqdn} ${metrics_fqdn}"
      CERT_EMAIL=${certbot_email}
      CERT_STAGING=${certbot_staging}

  # ── GoAccess dashboard basic-auth ──────────────────────────────────────
  # Mode 0644: nginx worker processes run as the non-root "nginx" user, but this
  # file is bind-mounted from the host where it's owned by deploy. At 0640 the
  # worker (neither owner nor group) can't read it and basic-auth fails with
  # "open() .../.htpasswd failed (13: Permission denied)". It holds only hashed
  # passwords on a single-tenant VM, so world-readable is fine.
  - path: /opt/openkoutsi/nginx/.htpasswd
    permissions: "0644"
    content: |
      ${goaccess_htpasswd}

  # ── Poll-based deploy unit + timer + script ────────────────────────────
  - path: /etc/systemd/system/okdeploy.service
    permissions: "0644"
    content: |
      ${indent(6, okdeploy_service)}

  - path: /etc/systemd/system/okdeploy.timer
    permissions: "0644"
    content: |
      ${indent(6, okdeploy_timer)}

  - path: /opt/openkoutsi/scripts/okdeploy-pull.sh
    permissions: "0755"
    content: |
      ${indent(6, okdeploy_pull)}

  # ── Service-log retention prune unit + timer + script ──────────────────
  - path: /etc/systemd/system/oklog-prune.service
    permissions: "0644"
    content: |
      ${indent(6, oklog_prune_service)}

  - path: /etc/systemd/system/oklog-prune.timer
    permissions: "0644"
    content: |
      ${indent(6, oklog_prune_timer)}

  - path: /opt/openkoutsi/scripts/oklog-prune.sh
    permissions: "0755"
    content: |
      ${indent(6, oklog_prune)}

  # ── nginx access-log size-cap unit + timer + script ────────────────────
  - path: /etc/systemd/system/oknginx-logrotate.service
    permissions: "0644"
    content: |
      ${indent(6, oknginx_logrotate_service)}

  - path: /etc/systemd/system/oknginx-logrotate.timer
    permissions: "0644"
    content: |
      ${indent(6, oknginx_logrotate_timer)}

  - path: /opt/openkoutsi/scripts/oknginx-logrotate.sh
    permissions: "0755"
    content: |
      ${indent(6, oknginx_logrotate)}

  - path: /opt/openkoutsi/scripts/init-certs.sh
    permissions: "0755"
    content: |
      ${indent(6, init_certs)}

  # ── Secrets — one file per pydantic field ──────────────────────────────
  # File names MUST equal the lowercase settings field names so that
  # pydantic-settings' secrets_dir=/run/secrets reads them.
  #
  # Mode 0444 (world-readable): Compose bind-mounts each file into the app
  # containers at /run/secrets/<name>, preserving the host owner/mode. The
  # backend runs as a non-root user, so 0400 (owner-only, and bootstrap chowns
  # these to deploy) gives it PermissionError reading its own secrets. The VM is
  # single-tenant and user_data already carries these secrets in plaintext, so
  # world-readable adds no meaningful exposure.
  - path: /opt/openkoutsi/secrets/secret_key
    permissions: "0444"
    content: ${secret_key}
  - path: /opt/openkoutsi/secrets/encryption_key
    permissions: "0444"
    content: ${encryption_key}
  - path: /opt/openkoutsi/secrets/strava_client_secret
    permissions: "0444"
    content: ${strava_client_secret}
  - path: /opt/openkoutsi/secrets/bridge_secret
    permissions: "0444"
    content: ${bridge_secret}
  - path: /opt/openkoutsi/secrets/wahoo_client_secret
    permissions: "0444"
    content: ${wahoo_client_secret}
  - path: /opt/openkoutsi/secrets/wahoo_bridge_secret
    permissions: "0444"
    content: ${wahoo_bridge_secret}
  - path: /opt/openkoutsi/secrets/wahoo_webhook_token
    permissions: "0444"
    content: ${wahoo_webhook_token}

  # ── First-boot provisioning script ─────────────────────────────────────
  - path: /opt/openkoutsi/scripts/bootstrap.sh
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      DATA_MOUNT="${data_mount}"
      LOG_MOUNT="${log_mount}"
      DATA_DEV="/dev/vdb"   # second virtio device = the encrypted data storage

      # Install Docker engine + compose plugin from Docker's apt repo.
      install -m 0755 -d /etc/apt/keyrings
      curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
        -o /etc/apt/keyrings/docker.asc
      chmod a+r /etc/apt/keyrings/docker.asc
      . /etc/os-release
      echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] \
      https://download.docker.com/linux/ubuntu $${VERSION_CODENAME} stable" \
        > /etc/apt/sources.list.d/docker.list
      apt-get update -y
      apt-get install -y docker-ce docker-ce-cli containerd.io \
        docker-buildx-plugin docker-compose-plugin
      systemctl enable --now docker

      # Format (first boot only) and mount the encrypted data device.
      if ! blkid "$${DATA_DEV}" >/dev/null 2>&1; then
        mkfs.ext4 -L okdata "$${DATA_DEV}"
      fi
      mkdir -p "$${DATA_MOUNT}"
      grep -q "$${DATA_MOUNT}" /etc/fstab || \
        echo "LABEL=okdata $${DATA_MOUNT} ext4 defaults,noatime 0 2" >> /etc/fstab
      mount -a
      mkdir -p "$${DATA_MOUNT}"/{backend,strava_bridge,wahoo_bridge,letsencrypt,certbot_www}

      # Logs live on the OS disk (NOT the encrypted data device): transient,
      # retention-pruned, and intentionally excluded from the data volume/backups.
      mkdir -p "$${LOG_MOUNT}"/{nginx_logs,service_logs}

      chown -R deploy:deploy /opt/openkoutsi

      # The backend and bridge containers run as a non-root user whose uid does
      # not match the host's deploy owner, yet they must create their SQLite DBs
      # (+ WAL/journal sidecars) and uploads inside these bind-mounted dirs.
      # Without write access SQLite fails with "unable to open database file".
      # Make the data dirs world-writable so any container uid can write; the VM
      # is single-tenant, so this is an acceptable trade-off. (letsencrypt/
      # certbot_www are written by the root certbot container, so they don't
      # need this.)
      chmod 0777 "$${DATA_MOUNT}"/{backend,strava_bridge,wahoo_bridge}

      # Optional: log in to GHCR for private packages (no-op when public).
      if [ -n "${ghcr_username}" ] && [ -n "${ghcr_token}" ]; then
        echo "${ghcr_token}" | docker login ghcr.io -u "${ghcr_username}" --password-stdin
      fi

      # Bring the stack up and enable the poll timer.
      cd /opt/openkoutsi

      # Non-secret config for compose variable interpolation (DATA_MOUNT,
      # LOG_MOUNT, *_URL, ...). Without this the bind-mount volume devices
      # expand to empty (e.g. /backend) and containers are created but fail
      # to start. okdeploy-pull.sh sources this the same way.
      set -a
      # shellcheck disable=SC1091
      . /opt/openkoutsi/stack.env
      set +a

      docker compose pull -q || true

      # First-boot TLS: obtain the real cert before the full stack comes up, so
      # nginx serves valid HTTPS immediately. Best-effort — if DNS isn't pointing
      # at this VM yet the request fails and nginx keeps the temporary self-signed
      # cert; re-run `bash scripts/init-certs.sh` once DNS resolves.
      bash /opt/openkoutsi/scripts/init-certs.sh || \
        echo "init-certs: cert bootstrap failed (DNS not ready?); re-run after DNS points here."

      docker compose up -d
      systemctl daemon-reload
      systemctl enable --now okdeploy.timer
      systemctl enable --now oklog-prune.timer
      systemctl enable --now oknginx-logrotate.timer

runcmd:
  - [bash, /opt/openkoutsi/scripts/bootstrap.sh]
