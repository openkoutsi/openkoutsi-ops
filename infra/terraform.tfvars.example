# Copy to terraform.tfvars (gitignored) or pass secrets via TF_VAR_* env vars.
# Non-secret values can live here; keep real secrets out of version control.

# ── Infrastructure ──────────────────────────────────────────────────────────
zone           = "fi-hel1"
server_plan    = "STARTER-2xCPU-2GB"
hostname       = "openkoutsi-prod"
data_disk_size = 50

# ── Data backups (UpCloud-managed, same-zone snapshots; defaults shown) ───────
# backup_interval  = "daily"  # daily | mon..sun
# backup_time      = "0100"   # UTC HHMM
# backup_retention = 7        # days to keep each backup

# ── Access ──────────────────────────────────────────────────────────────────
admin_cidr      = "203.0.113.10/32" # your admin IP — SSH is allowed only from here
ssh_public_keys = ["ssh-ed25519 AAAA... you@host"]

# ── DNS / domains (set matching A records at your registrar) ─────────────────
# The apex domain serves the static landing page; the web app lives on web_host
# (default "app", i.e. app.<domain>).
domain        = "openkoutsi.example"
certbot_email = "admin@openkoutsi.example"
# certbot_staging = true   # use LE staging while testing first-boot, then set false
# web_host / api_host / strava_bridge_host / wahoo_bridge_host / stats_host /
# logs_host / metrics_host default to app / api / bridge / wahoo-bridge / stats /
# logs / metrics — override only if needed.

# ── Non-secret app config ────────────────────────────────────────────────────
strava_client_id    = "12345"
wahoo_client_id     = ""
# LLM base URL / model / API key are set on the admin settings page, not here.
llm_allowed_servers = "" # env-only SSRF allowlist (optional)

# Outbound email (issue #15) — enables self-serve signup + password reset.
# Leave email_from empty (and the API-key secret unset) to keep email disabled.
email_provider = "lettermint" # or "euromail"
email_from     = ""

# ── Dashboard auth (htpasswd -nB admin) ──────────────────────────────────────
# goaccess_htpasswd = "admin:$2y$05$..."   # set via TF_VAR_goaccess_htpasswd

# ── Secrets — prefer TF_VAR_* env vars or a gitignored secrets.auto.tfvars ────
# secret_key           = "..."
# encryption_key       = "..."
# strava_client_secret = "..."
# bridge_secret        = "..."
# wahoo_client_secret  = ""
# wahoo_bridge_secret  = "..."
# wahoo_webhook_token  = "..."
# lettermint_api_key   = "..."   # outbound email (EMAIL_PROVIDER=lettermint)
# euromail_api_key     = "..."   # outbound email (EMAIL_PROVIDER=euromail)

# ── GHCR (leave empty — images are public) ───────────────────────────────────
# ghcr_username = ""
# ghcr_token    = ""
